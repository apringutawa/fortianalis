# FortiAnalis Backend Environment Configuration
# Copy this file to .env and fill in the values

# Gemini AI API Key (optional - for AI-powered security insights)
GEMINI_API_KEY=

# CORS Allowed Origins (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:3000,http://yourdomain.com

# API Version
API_V1_STR=/api/v1

# Project Name
PROJECT_NAME=FortiWeb Log Analyzer API
